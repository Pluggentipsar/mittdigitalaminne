{
  "manifest_version": 3,
  "name": "Mitt Digitala Minne",
  "version": "1.1.0",
  "description": "Spara den här sidan till Mitt Digitala Minne",
  "permissions": ["activeTab", "storage"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.svg",
      "48": "icons/icon-48.svg",
      "128": "icons/icon-128.svg"
    }
  },
  "icons": {
    "16": "icons/icon-16.svg",
    "48": "icons/icon-48.svg",
    "128": "icons/icon-128.svg"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+M",
        "mac": "Alt+M"
      },
      "description": "Spara sidan till Mitt Digitala Minne"
    }
  },
  "options_page": "options.html",
  "host_permissions": ["<all_urls>"]
}
