# =============================================================
# Mitt Digitala Minne — Web App Environment Variables
# =============================================================
# Kopiera denna fil till .env.local och fyll i dina värden:
#   cp .env.example .env.local
#
# Hämta värdena från: https://supabase.com/dashboard/project/DITT_PROJEKT/settings/api
# =============================================================

# Supabase — Publika (exponeras i klienten, det är OK)
NEXT_PUBLIC_SUPABASE_URL=https://DITT_PROJEKT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...din-anon-key-här

# Supabase — Hemlig (används enbart server-side i API routes)
# ⚠️  DELA ALDRIG denna nyckel! Den kringgår Row Level Security.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...din-service-role-key-här
